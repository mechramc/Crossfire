# =============================================================================
# CROSSFIRE .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Internal working docs (not for public repo)
# -----------------------------------------------------------------------------
tasks.md
checkpoint.md
status.md
CROSSFIRE-X_Implementation_Spec.md
*.docx
!CROSSFIRE-X_Implementation_Spec.md
!CROSSFIRE-X_Spec.docx
notes/
drafts/

# Claude Code local config
.claude/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env
.env.*

# -----------------------------------------------------------------------------
# ML artifacts (large files — do not commit)
# -----------------------------------------------------------------------------
models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.mlmodelc
*.mlpackage

# Raw benchmark data (processed results ARE tracked)
results/raw/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
.cache/
.ruff_cache/
.pytest_cache/
.mypy_cache/
